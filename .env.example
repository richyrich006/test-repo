# ============================================================
# Polymarket Trade Copier - Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER share or commit your .env file.

# ------ WHO TO COPY ------
# The Polymarket wallet address of the trader you want to copy.
# To find RN1's address: visit https://polymarket.com/profile/RN1
# and copy the wallet address shown in the URL or on their page.
TARGET_ADDRESS=0xYourTargetTraderAddressHere

# ------ YOUR WALLET ------
# Your Polygon wallet PRIVATE KEY (starts with 0x).
# This wallet needs USDC on Polygon to place trades.
# WARNING: Keep this secret. Anyone with this key controls your funds.
PRIVATE_KEY=0xYourPrivateKeyHere

# ------ TRADE SIZING ------
# How much of each trade to copy, as a fraction of the original.
# 1.0 = copy 100% of the trade size
# 0.5 = copy 50% (half the size)
# 0.1 = copy 10%
COPY_FRACTION=0.1

# Maximum USDC to spend on any single copied trade (safety limit).
MAX_TRADE_SIZE_USDC=50.0

# Minimum trade size to bother copying (skip tiny trades).
MIN_TRADE_SIZE_USDC=1.0

# Max slippage vs the target's fill price (0.03 = 3%).
# Orders are placed as limit FOK at price × (1 + this) for buys.
# Raise to 0.05 on illiquid markets to get more fills; lower to 0.01 to protect price.
MAX_SLIPPAGE_PCT=0.03

# ------ LIVE MODE (fastest — recommended) ------
# For ~2-5 second latency, connect directly to the Polygon blockchain.
#
# Step 1: Go to https://dashboard.alchemy.com/ and create a free account.
# Step 2: Create a new app → select "Polygon" → "Mainnet".
# Step 3: Click "View key" and copy the "WebSockets" URL (starts with wss://).
# Step 4: Paste it below.
#
# Alternative free public node (works but less reliable):
#   WEB3_WS_URL=wss://polygon-bor-rpc.publicnode.com
WEB3_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# ------ POLLING (fallback, run with --mode poll) ------
# Only used if you run: python copier.py --mode poll
# How often to check for new trades, in seconds.
POLL_INTERVAL_SECONDS=10

# ------ POLYMARKET API ------
# Leave these as-is unless Polymarket changes their endpoints.
CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# ------ CHAIN ------
# Polygon mainnet chain ID. Do not change.
CHAIN_ID=137
