{
  "manifest_version": 3,
  "name": "ReadAloud",
  "version": "1.0.0",
  "description": "Read any article aloud — automatically skips ads, headers, footers, and clutter.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://api.anthropic.com/*", "https://api.elevenlabs.io/*", "https://api.jamendo.com/*", "https://storage.jamendo.com/*", "wss://speech.platform.bing.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["Readability.js", "podcast.js", "discussion.js", "content.js"],
      "css": ["player.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ReadAloud",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
